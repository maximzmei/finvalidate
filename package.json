{
  "name": "finvalidate",
  "version": "1.0.0",
  "description": "AI code reviewer for TypeScript/Node.js fintech",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --minify",
    "test": "vitest run",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.52.0",
    "@octokit/rest": "^21.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.0",
    "express": "^5.2.1",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
